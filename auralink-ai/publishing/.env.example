# App
PORT=8001
APP_URL=http://localhost:8001
# Max POST body for /api/listings (base64 images). Default 31mb; Cloud Run max request ~32 MiB — do not set above ~31mb.
# JSON_BODY_LIMIT=31mb
# Use https://localhost:3000 when running Next with: npm run dev:https:no-open (repo: npm run dev:all:https)
FRONTEND_URL=http://localhost:3000
JWT_SECRET=your-jwt-secret-min-32-chars
# Optional: if set, must match Next.js PUBLISHING_JWT_SECRET. Used to verify signed Shopify OAuth start_token from /api/shopify/oauth-start.
# PUBLISHING_JWT_SECRET=
# Production: do not set. Dev only: allow bare ?user_id= on GET /auth/shopify (not for App Store).
# ALLOW_LEGACY_SHOPIFY_USER_ID_QUERY=1
# Set to 1 to hide public OAuth install (status.public_install_enabled). Default is enabled when unset.
# SHOPIFY_PUBLIC_INSTALL_DISABLED=1

# Enabled platforms (comma-separated). Launch with Shopify only, then add more.
ENABLED_PLATFORMS=shopify

# Database
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Token encryption (min 32 chars)
TOKEN_ENCRYPTION_KEY=your-32-char-encryption-key!!

# Shopify OAuth (required for the normal “Connect store” flow).
# Client ID + secret from Partners → your app → API credentials.
# See SHOPIFY-CUSTOM-APP-SETUP.md. For local-only testing without OAuth, set SHOPIFY_DEV_* below;
# the Connect page will offer “Continue without OAuth” when OAuth vars are empty.
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# App Store: mandatory GDPR webhooks (single URL for all three topics in Partner Dashboard):
#   POST {APP_URL}/webhooks/shopify/compliance
# Requires SHOPIFY_API_SECRET (or SHOPIFY_CLIENT_SECRET) for webhook HMAC. See SHOPIFY-APP-STORE-LAUNCH.md and shopify.app.toml.
#
# Optional: raw body limit for compliance webhook handler (express.raw). Increase if Partners test deliveries show 413.
# SHOPIFY_WEBHOOK_RAW_LIMIT=2mb

# Optional: skip OAuth; publish uses this Admin API token (dev / single-store only).
# SHOPIFY_DEV_ACCESS_TOKEN=
# SHOPIFY_DEV_SHOP_DOMAIN=your-store.myshopify.com
# When Supabase is enabled (e.g. Cloud Run), dev tokens are ignored unless you opt in (demo / one store for all users):
# SHOPIFY_DEV_TOKEN_APPLIES_IN_PRODUCTION=1
# Remove or set 0 before real multi-tenant App Store launch.
# On production, set DISABLE_DEV_SHOPIFY_CONNECT_BYPASS=1 if you must keep SHOPIFY_DEV_* set but hide Connect-page bypass.

# TikTok Shop
TIKTOK_APP_KEY=
TIKTOK_APP_SECRET=

# eBay (use sandbox for dev)
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
# RuName from eBay: Application Keys → User Tokens → add Redirect URL → copy RuName value here
EBAY_RUNAME=
EBAY_ENV=sandbox

# Etsy
ETSY_API_KEY=
ETSY_SHARED_SECRET=

# Amazon SP-API
AMAZON_CLIENT_ID=
AMAZON_CLIENT_SECRET=
AMAZON_SELLER_ID=
AMAZON_REFRESH_TOKEN=

# Optional: R2 for photos
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_ACCESS_KEY=
CLOUDFLARE_R2_SECRET_KEY=
