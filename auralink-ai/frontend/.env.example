## Clerk (required for auth)
# Get these from Clerk Dashboard → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

## Clerk JWT template (recommended when calling your own backend)
# Clerk Dashboard → JWT Templates → create e.g. "backend"
# - For client-side: NEXT_PUBLIC_CLERK_JWT_TEMPLATE=backend
# - For server-side /api/clerk/token: CLERK_JWT_TEMPLATE=backend
NEXT_PUBLIC_CLERK_JWT_TEMPLATE=backend
CLERK_JWT_TEMPLATE=backend

## Clerk URLs (recommended)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

## App URL (used for Stripe success/cancel redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

## Stripe (required for payments)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...

